{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client"]
  },
  "include": ["src"],
  "// exclude": "sw.ts targets the webworker lib and is compiled by vite-plugin-pwa (injectManifest), not by vue-tsc/tsc -b.",
  "exclude": ["src/sw.ts"]
}
