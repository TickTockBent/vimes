# VIMES daemon environment — copy to /etc/vimes/env, chmod 600, root-owned.
# Without the two ACCESS values the daemon runs FAIL-CLOSED (503 everything):
# safe behind the live tunnel, useless until they land.

VIMES_PORT=4600
VIMES_DB_PATH=/home/ticktockbent/.vimes/events.db
VIMES_STATIC_DIR=/home/ticktockbent/projects/infrastructure/vimes/packages/ui/dist
VIMES_PROJECT_ROOTS=/home/ticktockbent/projects/games/dongfu

# From the Cloudflare Access application (Wes provides — runbook §1):
#VIMES_ACCESS_TEAM_DOMAIN=<team>.cloudflareaccess.com
#VIMES_ACCESS_AUD=<application aud tag>

# ⟨tune PREVIEW⟩ knobs — defaults apply when unset:
#VIMES_SNAPSHOT_INTERVAL_MS=60000
#VIMES_WS_BUFFERED_LIMIT=4194304
#VIMES_SDK_SETTING_SOURCES=project

# ─── the stage-run watchdog (slice 6 step 5b) ────────────────────────────────
# The watchdog DETECTS AND REPORTS stale stage runs. It does NOT quarantine and
# does NOT retry — that half waits on Gate-D sign-off for the retry ⟨tune⟩s.
#
# Sampling cadence, not a threshold: bounds how soon a stall is NOTICED, never
# whether a run is stale (staleness is measured from event timestamps). 0
# disables the watchdog entirely — no timer is created.
#VIMES_WATCHDOG_CHECK_MS=60000
#
# The staleness band. PINNED at 15 min by D30 (Gate-D, signed off 2026-07-22)
# against spike S3a: 70,232 healthy machine-work gaps clear it, the longest
# observed being 14.87 min. A real calibrated default, not a placeholder — see
# docs/decisions.md D30 for the assumptions it carries.
#VIMES_WATCHDOG_STALE_AFTER_MS=900000
#
# ⟨tune PREVIEW — UNPINNED⟩ Episodes before the decision returns `quarantine`,
# and the backoff curve. NOTHING DESTRUCTIVE READS EITHER TODAY: their only
# effect is the `wouldQuarantine` flag recorded on a watchdog_stale, which is the
# calibration column for pricing them against real work before anything acts.
# An EMPTY backoff curve is refused at the config boundary (it would mean "retry
# immediately" once retries exist).
#VIMES_WATCHDOG_MAX_STALE_EPISODES=3
#VIMES_WATCHDOG_BACKOFF_MS=60000,300000,900000

# ─── worker isolation (slice 6 step 8) ───────────────────────────────────────
# ⚠ SHIPPED OFF. The whole worktree path is built, wired and tested; this flag is
# what turns it on, and turning it on CHANGES WHERE REAL WORK EXECUTES on this
# machine — new directories on a real disk, new branches in a real repo, agents
# editing files nobody is watching. That is a deliberate human decision (rule 0),
# the same discipline the watchdog's destructive half is under.
#
#   off (default) — every task, including one whose record says
#                   isolation:'worktree', runs in its task.projectRoot. Exactly the
#                   behaviour before step 8; NO git command is issued on any
#                   dispatch path. D32 is not honoured yet, and the code says so.
#   on            — an isolation:'worktree' task runs in its own git worktree.
#                   A task that asks for 'shared-dir' still runs in projectRoot.
#
# An unrecognised value is REFUSED at boot rather than read as 'off': an operator
# who wrote `=true` and believed their workers were isolated would otherwise be
# running everything in the shared directory with nothing to tell them.
#
# ⚠ A worktree that CANNOT be created never falls back to projectRoot. The dispatch
# reports `worktree-failed`, spawns nothing, and writes no session attachment.
#VIMES_WORKTREE_ISOLATION=off
#
# Where task worktrees live. Defaults to a SIBLING of the data dir
# (VIMES_DATA_DIR, itself defaulting to the db's directory) — e.g. ~/.vimes →
# ~/.vimes-worktrees. Keep it OUTSIDE every VIMES_PROJECT_ROOTS entry: the file
# browser lists what is under the allowlist, so a worktree root inside a project
# root would make every task's private worker directory appear as if it were a
# project, and would put N checkouts inside the tree the allowlist exists to fence.
#VIMES_WORKTREE_ROOT=/home/ticktockbent/.vimes-worktrees
